{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<div class="d-flex align-items-center gap-3">
				<div class="profile-avatar">
					{% if foto_parlamentar %}
						<img src="{{ foto_parlamentar }}" alt="{{ usuario.nome|default('Foto do parlamentar') }}" class="rounded-circle">
					{% else %}
						<div class="profile-avatar-fallback d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary">
							<i class="bi bi-person-fill"></i>
						</div>
					{% endif %}
				</div>
				<div>
					<h5 class="card-title fw-bold text-dark mb-0">{{ usuario.gabinete.nome }}/{{ usuario.gabinete.estado }}</h5>
					<p class="card-text text-muted mb-0 small">
						{{ usuario.gabinete.tipo_gabinete.nome|default('') }}
						{% if usuario.gabinete.cidade %}
							&middot;
							{{ usuario.gabinete.cidade }}
						{% endif %}
					</p>
				</div>
			</div>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">

			<div class="d-flex align-items-center gap-1 mb-3 ">
				<h6 class="fw-bold text-muted mb-0 text-uppercase small">
					Meus dados</h6>
			</div>

			{% if status == 'success' %}
				<div class="alert alert-success d-flex align-items-center gap-2 py-2 px-3 border-0 small fw-semibold mb-2" data-time="3">
					<i class="bi bi-check-circle-fill"></i>
					{{ message }}
				</div>
			{% endif %}

			{% if status == 'info' %}
				<div class="alert alert-info d-flex align-items-center gap-2 py-2 px-3 border-0 small fw-semibold mb-2" data-time="5">
					<i class="bi bi-info-circle-fill"></i>
					{{ message }}
				</div>
			{% endif %}

			{% if status == 'server_error' %}
				<div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 small fw-semibold mb-2">
					<i class="bi bi-exclamation-triangle-fill"></i>
					{{ message }}
					{{ error_id }}
				</div>
			{% endif %}

			<form class="row g-2 custom-form" id="form_novo" method="POST" action="/meu-gabinete">

				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="nome" placeholder="Nome" value="{{ usuario.nome|default('') }}">
				</div>

				<div class="col-md-3 col-12">
					<input type="email" class="form-control form-control-sm" name="email" placeholder="Email" value="{{ usuario.email|default('') }}">
				</div>

				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="telefone" data-mask="(00) 00000-0000" placeholder="Telefone" value="{{ usuario.telefone|default('') }}">
				</div>

				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="aniversario" data-mask="00/00" placeholder="dd/mm" value="{{ usuario.aniversario ? usuario.aniversario|date('d/m') : '' }}">
				</div>

				<div class="col-md-2 col-12 d-flex align-items-end">
					<button type="submit" class="btn btn-success btn-sm confirm w-100" data-text="Deseja atualizar seus dados?" name="btn_salvar">
						<i class="bi bi-floppy-fill"></i>
						Salvar
					</button>
				</div>

			</form>
		</div>
	</div>

	{% if mostrarUsuarios %}
		<div class="card border-0 bg-light mb-2">
			<div class="card-body p-3">
				<div class="d-flex align-items-center  mb-2 ">
					<h6 class="fw-bold text-muted mb-0 text-uppercase small">Cadastrar novos usuários</h6>
				</div>
				<p class="text-muted small mb-2">Compartilhe o link abaixo para que novos membros se cadastrem diretamente neste gabinete:</p>
				<div class="input-group input-group-sm">
					<input type="text" class="form-control bg-white" style="font-size: 0.9em;" id="linkConvite" value="{{ url_convite }}" readonly>
					<button class="btn btn-success" type="button" style="font-size: 0.9em;" onclick="copiarLink()">
						<i class="bi bi-copy"></i>
						Copiar
					</button>
				</div>
			</div>
		</div>
		<div class="card border-0 shadow-sm mb-2">
			<div class="card-body p-3">
				<div class="d-flex align-items-center gap-1 mb-3">
					<h6 class="fw-bold text-success mb-0 text-uppercase small">
						<i class="bi bi-person-check-fill me-1"></i>
						Usuários Ativos
					</h6>
				</div>

				<div class="table-responsive">
					<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
						<thead>
							<tr class="text-muted small text-uppercase">
								<th scope="col">Nome</th>
								<th scope="col">Email</th>
								<th scope="col">Telefone</th>
								<th scope="col">Incluído</th>
							</tr>
						</thead>
						<tbody>
							{% set tem_ativo = false %}
							{% for item in usuarios %}
								{% if item.ativo %}
									{% set tem_ativo = true %}
									<tr>
										<td class="fw-semibold">
											<a href="/usuario/{{ item.id }}">{{ item.nome }}</a>
										</td>

										<td class="text-muted">{{ item.email }}</td>
										<td class="text-muted">{{ item.telefone|default('-') }}</td>
										<td class="text-muted">{{ item.created_at|date('d/m/Y') }}</td>
									</tr>
								{% endif %}
							{% endfor %}

							{% if not tem_ativo %}
								<tr>
									<td colspan="5" class="text-center text-muted py-3">Nenhum usuário ativo encontrado.</td>
								</tr>
							{% endif %}
						</tbody>
					</table>
				</div>
			</div>
		</div>

		<div class="accordion mb-2" id="accordionDesativados">
			<div class="accordion-item border-0 shadow-sm rounded-3 overflow-hidden">
				<h2 class="accordion-header">
					<button class="accordion-button collapsed bg-white text-danger fw-bold text-uppercase py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDesativados" aria-expanded="false" aria-controls="collapseDesativados" style="font-size: 0.38em;">
						<i class="bi bi-person-x-fill me-2"></i>
						Usuários Desativados
					</button>
				</h2>
				<div id="collapseDesativados" class="accordion-collapse collapse" data-bs-parent="#accordionDesativados">
					<div class="accordion-body p-3 bg-white">

						<div class="table-responsive">
							<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
								<thead>
									<tr class="text-muted small text-uppercase">
										<th scope="col">Nome</th>
										<th scope="col">Status</th>
										<th scope="col">Email</th>
										<th scope="col">Telefone</th>
										<th scope="col">Incluído</th>
									</tr>
								</thead>
								<tbody>
									{% set tem_desativado = false %}
									{% for item in usuarios %}
										{% if not item.ativo %}
											{% set tem_desativado = true %}
											<tr>
												<td class="fw-semibold">
													<a href="/usuario/{{ item.id }}">{{ item.nome }}</a>
												</td>
												<td>
													<span class="badge rounded-pill text-bg-secondary">
														<i class="bi bi-dash-circle me-1"></i>
														Desativado
													</span>
												</td>
												<td class="text-muted">{{ item.email }}</td>
												<td class="text-muted">{{ item.telefone|default('-') }}</td>
												<td class="text-muted">{{ item.created_at|date('d/m/Y') }}</td>
											</tr>
										{% endif %}
									{% endfor %}

									{% if not tem_desativado %}
										<tr>
											<td colspan="5" class="text-muted">Nenhum usuário desativado encontrado.</td>
										</tr>
									{% endif %}
								</tbody>
							</table>
						</div>

					</div>
				</div>
			</div>
		</div>
	{% endif %}


	<script>
		function copiarLink () {
				var copyText = document.getElementById ("linkConvite");
				copyText.select ();
				copyText.setSelectionRange (0, 99999); // Para dispositivos móveis
				navigator.clipboard.writeText (copyText.value);

				// Opcional: Mudar o texto do botão temporariamente para dar feedback
				const btn = event.currentTarget;
				const originalHTML = btn.innerHTML;
				btn.innerHTML = '<i class="bi bi-check-lg"></i> Copiado!';
				btn.classList.remove ('btn-success');
				btn.classList.add ('btn-outline-success');

				setTimeout ( () => {
				btn.innerHTML = originalHTML;
				btn.classList.remove ('btn-outline-success');
				btn.classList.add ('btn-success');
				}, 2000);
		}
	</script>
{% endblock %}
