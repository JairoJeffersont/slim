{% extends "layouts/guest.twig" %}


{% block content %}
<div class="container py-5">
    <div class="row justify-content-center py-5">
        <div class="col-md-5 col-12 text-center">

            <div class="card border-0 shadow-sm p-4">
                <div class="card-body">
                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-circle" style="width: 80px; height: 80px;">
                            <i class="bi bi-check-circle-fill text-success fs-1"></i>
                        </div>
                    </div>

                    <h3 class="fw-bold text-dark mb-2">Cadastro Confirmado!</h3>
                    <p class="text-muted mb-4">
                        Muito obrigado! Seus dados foram salvos com sucesso e você já faz parte da nossa rede de relacionamentos.
                    </p>

                    <hr class="my-4 text-muted opacity-25">

                    <p class="small text-secondary mb-0">
                        Você já pode fechar esta página com segurança.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
