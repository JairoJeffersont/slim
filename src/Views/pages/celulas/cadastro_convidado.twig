{% extends "layouts/guest.twig" %}

{% block content %}
	<div class="container-fluid d-flex justify-content-center align-items-center py-4" style="min-height: 100dvh;">
		<div class="card border-0 bg-transparent" style="width: 100%; max-width: 470px;">
			<div class="card-body">
				<div class="text-center mb-3">
					<img src="img/logo_white.png" alt="Logo" class="img-fluid" style="max-width: 100px;">
				</div>

				<h2 class="text-center mb-2 text-white fw-light">
					{{ app_name }}
				</h2>

				<p class="card-text text-center text-white mb-4">Você foi convidado por
					<strong>{{ lider.nome }}</strong>
					para fazer parte da nossa rede!</p>

				{% if status in ['success', 'info'] %}
					<div class="alert alert-{{ status }} rounded-pill py-2 px-4 border-0 text-center small fw-semibold mb-2">
						{{ message }}
					</div>
				{% endif %}

				{% if status == 'error' %}
					<div class="alert alert-danger rounded-pill py-2 px-4 border-0 text-center small fw-semibold mb-2">
						{{ message }}
						{{ error_id }}
					</div>
				{% endif %}

				<form class="row g-2 custom-form" method="POST" action="/convite/salvar?token={{ token }}">
					<div class="col-12">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="nome" placeholder="Seu nome completo" required>
					</div>

					<div class="col-12">
						<input type="email" class="form-control rounded-pill py-2 px-4 border-0" name="email" placeholder="E-mail" required>
					</div>

					<div class="col-6">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="telefone" placeholder="Telefone" data-mask="(00) 00000-0000" required>
					</div>

					<div class="col-6">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="aniversario" placeholder="Aniversário (dd/mm)" data-mask="00/00" required>
					</div>

					<div class="col-6">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="endereco" placeholder="Endereço" required>
					</div>

					<div class="col-6">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="bairro" placeholder="Bairro" required>
					</div>

					<div class="col-6">
						<select class="form-select rounded-pill py-2 px-4 border-0" name="estado" id="uf" required>
							<option disabled selected value="">Escolha o estado*</option>
						</select>
					</div>

					<div class="col-6">
						<select class="form-select rounded-pill py-2 px-4 border-0" name="cidade" id="municipio" required>
							<option disabled selected value="">Selecione o município*</option>
						</select>
					</div>

					<div class="col-6">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="instagram" placeholder="Instagram">
					</div>

					<div class="col-6">
						<input type="text" class="form-control rounded-pill py-2 px-4 border-0" name="facebook" placeholder="Facebook">
					</div>

					<div class="col-12 d-flex gap-2 mt-3">
						<button type="submit" class="btn btn-success rounded-pill py-2 w-100">Confirmar Cadastro</button>
					</div>
				</form>
				<div class="col-12 mt-3 text-center">
					<p class="text-white-50 small mb-0">
						<i class="bi bi-shield-check me-1"></i>
						Seus dados estão seguros e protegidos pela LGPD.
					</p>
				</div>
			</div>
		</div>
	</div>

	<script>
		$ (document).ready (function () {
popularEstadosBrasil ('#uf');
popularMunicipiosBrasil ('#uf', '#municipio');
});
	</script>
{% endblock %}
