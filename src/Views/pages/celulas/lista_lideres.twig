{% extends "layouts/app.twig" %}

{% block content %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
			<a class="btn btn-success btn-sm custom-nav" href="/pessoas" role="button">
				<i class="bi bi-arrow-left"></i>
				Voltar
			</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<div>
				<h6 class="mb-0 fw-bold mb-1">Lideranças e Células</h6>
				<small class="text-muted">
					Utilize esta seção para visualizar os líderes ativos, acompanhar a quantidade de liderados e monitorar a representação e o crescimento de cada célula na rede do gabinete.
				</small>
			</div>
		</div>
	</div>

	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">

			<div class="mb-2">
				<h6 class="fw-bold text-muted mb-1 text-uppercase small">Líderes de Célula ({{ lideres|length }})</h6>
				<span class="text-muted small">
					Total do Gabinete:
					{{ total_pessoas_gabinete }}
				</span>
			</div>

			<div class="table-responsive mb-0">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col" style="width: 50%;">Líder</th>
							<th scope="col" style="width: 20%;">Liderados</th>
							<th scope="col" style="width: 30%;">Representação na Rede</th>
						</tr>
					</thead>
					<tbody>
						{% for lider in lideres %}
							<tr>
								<td>
									<a href="/pessoas/{{ lider.id }}" class="fw-bold text-decoration-none">
										{{ lider.nome }}
									</a>
									<small class="text-muted d-block" style="font-size: 11px;">
										{{ lider.cidade|default('Cidade não informada') }}
										-
										{{ lider.estado }}
									</small>
								</td>

								<td>
									<span class="fw-semibold text-dark">{{ lider.total_liderados }}</span>
								</td>

								<td>
									<div class="d-flex align-items-center gap-2">
										<div class="progress flex-grow-1" style="height: 8px;">
											<div class="progress-bar bg-success" role="progressbar" style="width: {{ lider.porcentagem }}%;" aria-valuenow="{{ lider.porcentagem }}" aria-valuemin="0" aria-valuemax="100"></div>
										</div>
										<span class="small fw-bold text-dark">{{ lider.porcentagem }}%</span>
									</div>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="3" class="text-center text-muted">
									Nenhum líder cadastrado no sistema até o momento.
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>

{% endblock %}
