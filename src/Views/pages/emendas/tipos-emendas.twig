{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button"><i class="bi bi-house-door-fill"></i> Início</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<h6 class="mb-0 fw-bold mb-1">Gerenciamento de Tipos de Emenda</h6>
			<small class="text-muted">Cadastre e organize os tipos de emenda parlamentar.</small>
		</div>
	</div>

	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">{{ message }}</div>
	{% endif %}
	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">{{ message }} {{ error_id }}</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-2">
			<form class="row g-2 custom-form" method="POST" action="{% if tipo %}/emendas/tipos/{{ tipo.id }}/editar{% else %}/emendas/tipos{% endif %}">
				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="nome" value="{{ tipo.nome|default('') }}" placeholder="Tipo (Ex. Individual)" required>
				</div>
				<div class="col-md-7 col-12">
					<button type="submit" class="btn btn-success btn-sm confirm" data-text="{% if tipo %}Deseja atualizar este tipo?{% else %}Deseja inserir este tipo?{% endif %}">
						<i class="bi bi-floppy-fill"></i> {% if tipo %}Atualizar{% else %}Salvar{% endif %}
					</button>
					{% if not tipo %}
						<a href="/emendas/tipos/inserir/padrao" class="btn btn-primary btn-sm confirm" data-text="Deseja inserir os tipos padrão?">
							<i class="bi bi-plus-circle-fill"></i> Inserir tipos padrão
						</a>
					{% endif %}
				</div>
			</form>
		</div>
	</div>

	<div class="card border-0 shadow-sm">
		<div class="card-body p-2">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead><tr><th style="width:70%">Tipo</th><th style="width:30%">Ações</th></tr></thead>
					<tbody>
						{% for item in tipos %}
							<tr>
								<td><a href="/emendas/tipos/{{ item.id }}">{{ item.nome }}</a></td>
								<td><a href="/emendas/tipos/{{ item.id }}/apagar" class="confirm badge border border-danger text-danger text-decoration-none py-1.5" data-text="Tem certeza que deseja apagar este tipo?"><i class="bi bi-trash3-fill me-1"></i>Apagar</a></td>
							</tr>
						{% else %}
							<tr><td class="text-muted" colspan="2">Nenhum tipo de emenda encontrado.</td></tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
