{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button"><i class="bi bi-house-door-fill"></i> Início</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<h6 class="mb-0 fw-bold mb-1">Gerenciamento de Temas de Emenda</h6>
			<small class="text-muted">Cadastre e organize os temas das emendas (saúde, educação, etc.).</small>
		</div>
	</div>

	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">{{ message }}</div>
	{% endif %}
	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">{{ message }} {{ error_id }}</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-2">
			<form class="row g-2 custom-form" method="POST" action="{% if tema %}/emendas/temas/{{ tema.id }}/editar{% else %}/emendas/temas{% endif %}">
				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="nome" value="{{ tema.nome|default('') }}" placeholder="Tema (Ex. Saúde)" required>
				</div>
				<div class="col-md-7 col-12">
					<button type="submit" class="btn btn-success btn-sm confirm" data-text="{% if tema %}Deseja atualizar este tema?{% else %}Deseja inserir este tema?{% endif %}">
						<i class="bi bi-floppy-fill"></i> {% if tema %}Atualizar{% else %}Salvar{% endif %}
					</button>
					{% if not tema %}
						<a href="/emendas/temas/inserir/padrao" class="btn btn-primary btn-sm confirm" data-text="Deseja inserir os temas padrão?">
							<i class="bi bi-plus-circle-fill"></i> Inserir temas padrão
						</a>
					{% endif %}
				</div>
			</form>
		</div>
	</div>

	<div class="card border-0 shadow-sm">
		<div class="card-body p-2">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead><tr><th style="width:70%">Tema</th><th style="width:30%">Ações</th></tr></thead>
					<tbody>
						{% for item in temas %}
							<tr>
								<td><a href="/emendas/temas/{{ item.id }}">{{ item.nome }}</a></td>
								<td><a href="/emendas/temas/{{ item.id }}/apagar" class="confirm badge border border-danger text-danger text-decoration-none py-1.5" data-text="Tem certeza que deseja apagar este tema?"><i class="bi bi-trash3-fill me-1"></i>Apagar</a></td>
							</tr>
						{% else %}
							<tr><td class="text-muted" colspan="2">Nenhum tema de emenda encontrado.</td></tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
