{% extends "layouts/app.twig" %}

{% block content %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
		</div>
	</div>

	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<div>
				<h6 class="mb-0 fw-bold mb-1">Aniversariantes</h6>
				<small class="text-muted">
					Consulte os aniversariantes das pessoas do mandato para manter o relacionamento ativo enviando felicitações.
				</small>
			</div>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div
			class="card-body p-3">

			<!-- Seleção de Filtro (Dia / Mês) -->
			<div class="d-flex justify-content-between align-items-center mb-3">
				<div class="btn-group" role="group">
					<a href="/aniversariantes?filtro=dia" style="font-size:0.8em" class="btn btn-sm {% if filtro_atual == 'dia' %}btn-primary{% else %}btn-outline-secondary{% endif %}">
						Do Dia
					</a>
					<a href="/aniversariantes?filtro=mes" style="font-size:0.8em" class="btn btn-sm {% if filtro_atual == 'mes' %}btn-primary{% else %}btn-outline-secondary{% endif %}">
						Do Mês ({{ mes_nome }})
					</a>
				</div>

				<span class="text-muted small">
					Resultados encontrados:
					{{ aniversariantes|length }}
				</span>
			</div>

			<!-- Tabela de Aniversariantes -->
			<div class="table-responsive mb-0">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col" style="width: 40%;">Nome</th>
							<th scope="col" style="width: 15%;">Aniversário</th>
							<th scope="col" style="width: 25%;">Contato</th>
						</tr>
					</thead>
					<tbody>
						{% for niver in aniversariantes %}
							<tr>
								<td>
									<a href="{{ niver.link }}" >
										{{ niver.nome }}
									</a>

									{# Se for usuário (Equipe), exibe uma tag verde diferenciando #}
									{% if niver.tipo_registro == 'usuario' %}
										<span class="badge bg-success ms-1" style="font-size: 10px;">Equipe / Assessor </span>
									{% endif %}
								</td>
								<td>
									{# Formata o aniversário considerando que é um objeto de data #}
									{{ niver.aniversario|date('d/m') }}
								</td>
								<td>
									{{ niver.telefone|default('-') }}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="3">
									Nenhum aniversariante encontrado neste período.
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

		</div>
	</div>

{% endblock %}
