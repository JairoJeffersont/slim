{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<h6 class="mb-0 fw-bold mb-1">Agenda de Compromissos do Gabinete</h6>
			<small class="text-secondary">
				<i class="bi bi-calendar-event-fill"></i>
				Gerencie a rotina oficial, audiências e eventos do gabinete de forma centralizada, garantindo maior eficiência no planejamento das suas atividades.
			</small>
		</div>
	</div>
	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}

	{# --- FILTRO DE PESSOAS --- #}
	<div class="card mb-2 border-0 shadow-sm bg-light">
		<div class="card-body p-3">
			<h6 class="small fw-bold text-muted mb-2">
				<i class="bi bi-funnel-fill"></i>
				Filtrar pessoas por localização</h6>
			<form class="row g-2 custom-form" method="GET">
				<input type="hidden" name="tipo" value="{{ tipoGet }}">
				<input type="hidden" name="situacao" value="{{ situacaoGet }}">
				<input type="hidden" name="busca" value="{{ busca }}">
				<input type="hidden" name="data" value="{{ dataGet }}">
				<input type="hidden" name="periodo" value="{{ periodoGet|default('dia') }}">

				<div class="col-md-3">
					<select class="form-control form-control-sm" name="pessoa_estado" id="uf-pessoa-agenda" data-selected="{{ parametros_pessoas.estado }}">
						<option disabled selected value="">Estado</option>
					</select>
				</div>
				<div class="col-md-3">
					<select class="form-control form-control-sm" name="pessoa_cidade" id="municipio-pessoa-agenda" data-selected="{{ parametros_pessoas.cidade }}">
						<option disabled selected value="">Município</option>
					</select>
				</div>
				<div class="col-md-2">
					<button type="submit" class="btn btn-secondary btn-sm w-100">Filtrar</button>
				</div>
			</form>
		</div>
	</div>

	{# --- FORMULÁRIO DE CADASTRO --- #}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<h6 class="small fw-bold text-muted mb-2">Novo Compromisso</h6>
			<form class="row g-2 custom-form" method="POST">
				<div class="col-md-3 col-12">
					<div class="input-group">
						<select class="form-select form-select-sm agenda-select-link" data-link="/agenda/tipos" name="tipo_agenda_id" required>
							<option disabled selected value="">Tipo de Agenda*</option>
							{% for tipo in tipos %}
								<option value="{{ tipo.id }}">{{ tipo.nome }}</option>
							{% endfor %}
							<option value="+">+ Novo tipo</option>
						</select>
					</div>
				</div>

				<div class="col-md-3 col-12">
					<div class="input-group">
						<select class="form-select form-select-sm agenda-select-link" data-link="/agenda/situacoes" name="situacao_agenda_id" required>
							<option disabled selected value="">Situação*</option>
							{% for situacao in situacoes %}
								<option value="{{ situacao.id }}">{{ situacao.nome }}</option>
							{% endfor %}
							<option value="+">+ Nova situação</option>
						</select>
					</div>
				</div>

				<div class="col-md-6 col-12">
					<select class="form-select form-select-sm" name="pessoa_id">
						<option value="" selected>Sem pessoa vinculada</option>
						{% for pessoa in pessoas %}
							<option value="{{ pessoa.id }}">{{ pessoa.nome }}</option>
						{% endfor %}
					</select>
				</div>

				<div class="col-md-6 col-12">
					<input type="text" class="form-control form-control-sm" name="titulo" placeholder="Título do compromisso" required>
				</div>

				<div class="col-md-6 col-12">
					<input type="text" class="form-control form-control-sm" name="local" placeholder="Local">
				</div>

				<div class="col-md-6 col-12">
					<input type="datetime-local" class="form-control form-control-sm" name="data_hora" required>
				</div>

				<div class="col-md-6 col-12">
					<input type="datetime-local" class="form-control form-control-sm" name="data_hora_fim">
				</div>

				<div class="col-12">
					<textarea class="form-control form-control-sm" name="descricao" rows="2" placeholder="Descrição do compromisso"></textarea>
				</div>

				<div class="col-12 mt-2">
					<button type="submit" class="btn btn-success btn-sm confirm" data-text="Deseja salvar este compromisso?">
						<i class="bi bi-floppy-fill me-1"></i>
						Salvar Compromisso
					</button>
				</div>
			</form>
		</div>
	</div>

	{# --- TABELA DE COMPROMISSOS --- #}
	<div class="card border-0 shadow-sm">
		<div class="card-body p-3">
			{% set printQuery =
            'tipo=' ~ ((tipoGet is not null ? tipoGet : '')|url_encode) ~
            '&situacao=' ~ ((situacaoGet is not null ? situacaoGet : '')|url_encode) ~
            '&busca=' ~ (busca|default('')|url_encode) ~
            '&data=' ~ (dataGet|default('')|url_encode) ~
            '&periodo=' ~ (periodoGet|default('dia')|url_encode) ~
            '&pessoa_estado=' ~ (parametros_pessoas.estado|default('')|url_encode) ~
            '&pessoa_cidade=' ~ (parametros_pessoas.cidade|default('')|url_encode)
        %}

			<div class="d-flex justify-content-start mb-2">
				<a href="/agenda/imprimir?{{ printQuery }}" style="font-size:0.8em" target="_blank" class="btn btn-outline-secondary btn-sm">
					<i class="bi bi-printer-fill me-1"></i>
					Imprimir agenda
				</a>
			</div>

			<form class="row g-2 custom-form mb-4" method="GET">
				<input type="hidden" name="pessoa_estado" value="{{ parametros_pessoas.estado }}">
				<input type="hidden" name="pessoa_cidade" value="{{ parametros_pessoas.cidade }}">

				<div class="col-md-3">
					<select class="form-select form-select-sm" name="tipo">
						<option value="" {% if not tipoGet %} selected {% endif %}>Todos os tipos</option>
						{% for tipo in tipos %}
							<option value="{{ tipo.id }}" {% if tipoGet == tipo.id %} selected {% endif %}>{{ tipo.nome }}</option>
						{% endfor %}
					</select>
				</div>
				<div class="col-md-3">
					<select class="form-select form-select-sm" name="situacao">
						<option value="" {% if not situacaoGet %} selected {% endif %}>Todas as situações</option>
						{% for situacao in situacoes %}
							<option value="{{ situacao.id }}" {% if situacaoGet == situacao.id %} selected {% endif %}>{{ situacao.nome }}</option>
						{% endfor %}
					</select>
				</div>
				<div class="col-md-5">
					<input type="text" class="form-control form-control-sm" name="busca" value="{{ busca }}" placeholder="Buscar por título, local, descrição ou pessoa">
				</div>
				<div class="col-md-2">
					<select class="form-select form-select-sm" name="periodo">
						<option value="dia" {% if (periodoGet|default('dia')) == 'dia' %} selected {% endif %}>Dia</option>
						<option value="mes" {% if (periodoGet|default('dia')) == 'mes' %} selected {% endif %}>Mês</option>
						<option value="todos" {% if (periodoGet|default('dia')) == 'todos' %} selected {% endif %}>Todos</option>
					</select>
				</div>
				<div class="col-md-2">
					<input type="date" class="form-control form-control-sm" name="data" value="{{ dataGet }}">
				</div>
				<div class="col-md-1">
					<button type="submit" class="btn btn-success btn-sm w-100">
						<i class="bi bi-search"></i>
					</button>
				</div>
			</form>

			{# Nova Lista de Compromissos (Substituindo a Tabela) #}
			<div class="list-group list-group-flush gap-2">
				{% for item in agendas %}
					<div
						class="list-group-item bg-light rounded p-0 border-0 d-flex align-items-stretch gap-3 position-relative overflow-hidden mb-2">

						{# Bloco Lateral Dinâmico para Data e Horário #}
						<div class="bg-primary text-white p-2 d-flex flex-column align-items-center justify-content-center text-center flex-shrink-0" style="width: 85px; font-size: 0.85em; line-height: 1.2;">
							<span class="fw-bold d-block mb-1">{{ item.data_hora|date('d/m') }}</span>
							<span class="badge bg-white text-primary fw-bold px-1" style="font-size: 0.9em;">{{ item.data_hora|date('H:i') }}</span>
							{% if item.data_hora_fim %}
								<small class="opacity-75 mt-1" style="font-size: 0.75em;">
									até
									{{ item.data_hora_fim|date('H:i') }}
								</small>
							{% endif %}
						</div>

						{# Detalhes do Compromisso #}
						<div class="py-3 pe-3 w-100 row g-2">
							<div class="col-md-7">
								<h6 class="fw-bold text-dark mb-1 small">
									<a href="/agenda/{{ item.id }}" class="text-decoration-none text-dark hover-underline stretched-link">
										{{ item.titulo }}
									</a>
								</h6>
								{% if item.descricao %}
									<p class="text-muted mb-2 small text-truncate-custom" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
										{{ item.descricao }}
									</p>
								{% endif %}

								<div class="d-flex flex-wrap gap-2 mt-1">
									<span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill fw-medium" style="font-size: 11px;">
										<i class="bi bi-tag me-1"></i>
										{{ item.tipoAgenda.nome }}
									</span>
									<span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill fw-medium" style="font-size: 11px;">
										<i class="bi bi-info-circle me-1"></i>
										{{ item.situacaoAgenda.nome }}
									</span>
								</div>
							</div>

							{# Responsável e Local #}
							<div class="col-md-5 d-flex flex-column justify-content-center border-start-md ps-md-3" style="font-size: 13px; z-index: 2;">
								<div class="text-dark mb-1 text-truncate" title="Pessoa Vinculada">
									<i class="bi bi-person me-1 text-muted"></i>
									{{ item.pessoa.nome|default('Sem pessoa vinculada') }}
								</div>
								{% if item.local %}
									<div class="text-muted text-truncate" title="Local">
										<i class="bi bi-geo-alt me-1 text-danger"></i>
										{{ item.local }}
									</div>
								{% endif %}
							</div>
						</div>
					</div>
				{% else %}
					{# Estado Vazio #}
					<div class="text-center py-4 border border-dashed rounded bg-light-subtle">
						<small class="text-muted text-uppercase fw-semibold tracking-wider" style="font-size: 11px; letter-spacing: 0.5px;">
							<i class="bi bi-calendar-x me-1 opacity-75"></i>
							Nenhum compromisso encontrado.
						</small>
					</div>
				{% endfor %}
			</div>

		</div>
	</div>

	{# Opcional: Adicione essa regra CSS apenas se sua folha de estilos não cobrir bordas responsivas de grid do bootstrap #}
	<style>
		@media(min-width: 768px) {
			.border-start-md {
				border-left: 1px solid #dee2e6 !important;
			}
		}
	</style>

	<script>
		document.addEventListener ('DOMContentLoaded', function () {
popularEstadosBrasil ('#uf-pessoa-agenda');
popularMunicipiosBrasil ('#uf-pessoa-agenda', '#municipio-pessoa-agenda');

document.querySelectorAll ('.agenda-select-link').forEach (function (select) {
select.addEventListener ('change', function () {
if (this.value === '+') {
const link = this.dataset.link;
if (confirm ('Deseja cadastrar um novo item?')) {
window.location.href = link;
} else {
this.value = '';
}
}
});
});
});
	</script>
{% endblock %}
