{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<div>
				<h6 class="mb-0 fw-bold mb-1">Gerenciamento de Documentos</h6>
				<small class="text-muted d-block mb-2">
					Cadastre, visualize, edite e organize o arquivo físico e digital de documentos oficiais do gabinete.
				</small>
				<small class="text-secondary fw-bold">
					<i class="bi bi-info-circle-fill"></i>
					Formatos aceitos: PDF, Word e Excel.
				</small>
			</div>
		</div>
	</div>
	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">

			<form class="row g-2 custom-form" method="POST" enctype="multipart/form-data">
				<div class="col-md-3 col-12">
					<div class="input-group">
						<select class="form-select form-select-sm" name="tipo_documento_id" required>
							<option disabled selected value="">Tipo de Documento*</option>
							{% for tipo in tipos %}
								<option value="{{ tipo.id }}">
									{{ tipo.nome }}
									{% if tipo.siga %}({{ tipo.siga }})
									{% endif %}
								</option>
							{% endfor %}

							<option value="+">+ Novo tipo</option>
						</select>
						<a href="/documentos/tipos" class="btn btn-primary btn-sm confirm" data-text="Deseja cadastrar uma novo tipo de documento?">
							<i class="bi bi-plus-circle"></i>
						</a>
					</div>
				</div>

				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="numero" placeholder="Número (ex: 123)" required>
				</div>

				<div class="col-md-1 col-6">
					<input type="number" class="form-control form-control-sm" min="1900" max="2100" name="ano" data-mask="0000" placeholder="Ano" required>
				</div>
				<div class="col-md-6 col-12">
					<input type="file" class="form-control form-control-sm" name="arquivo" accept=".pdf,image/*" required>
				</div>

				<div class="col-12">
					<textarea class="form-control form-control-sm" name="resumo" rows="4" placeholder="Descrição detalhada, andamento ou observações importantes...">{{ documento.descricao|default('') }}</textarea>
				</div>

				<div class="col-12 mt-2">
					<button type="submit" class="btn btn-success btn-sm confirm" data-text="Deseja salvar as informações deste documento?">
						<i class="bi bi-floppy-fill me-1"></i>
						Salvar
					</button>
				</div>

			</form>
		</div>
	</div>

	<div class="card border-0 shadow-sm">
		<div class="card-body p-3">
			<form class="row g-2 custom-form mb-2" method="GET">

				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="ano" value="{{anoGet}}" placeholder="Ano">
				</div>

				<div class="col-md-3 col-12">
					<select class="form-select form-select-sm" name="tipo">
						<option value="" {% if not tipoget %} selected {% endif %}>Todos os Tipos</option>
						{% for tipo in tipos %}
							<option value="{{ tipo.id }}" {% if tipoGet == tipo.id %} selected {% endif %}>
								{{ tipo.nome }}
								{% if tipo.siga %}({{ tipo.siga }})
								{% endif %}
							</option>
						{% endfor %}
					</select>
				</div>

				<div class="col-md-1">
					<button type="submit" class="btn btn-success btn-sm">
						<i class="bi bi-search"></i>
					</button>
				</div>
			</form>
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col" style="width: 15%;">Documento</th>
							<th scope="col" style="width: 45%;">Título</th>
							<th scope="col" style="width: 45%;">Visualizar</th>
						</tr>
					</thead>
					<tbody>
						{% for doc in documentos %}
							<tr>
								<td>
									<a href="/documentos/{{doc.id}}">{{ doc.tipo.sigla }}
										{{ doc.numero }}/{{ doc.ano }}</a>
								</td>
								<td>
									{{ doc.titulo }}
								</td>
								<td>
									{{ doc.arquivo_url }}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="3">
									{%if anoGet%}
										Nenhum documento registrado para o ano de
										<b>{{anoGet}}</b>
										encontrado.
										{%else%}
										Nenhum documento registrado encontrado.
										{%endif%}</td>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<script>


		document.addEventListener ('DOMContentLoaded', function () {
const select = document.querySelector ('select[name="tipo_documento_id"]');

select.addEventListener ('change', function () {
if (this.value === '+') {
if (confirm ('Deseja inserir um novo tipo?')) {
window.location.href = '/documentos/tipos';
} else {
this.value = '';
}
}
});
});
	</script>
{% endblock %}
