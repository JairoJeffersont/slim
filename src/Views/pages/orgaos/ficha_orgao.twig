{% extends "layouts/app.twig" %}


{% block content %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
			<a class="btn btn-success btn-sm custom-nav" href="/orgaos" role="button">
				<i class="bi bi-arrow-left"></i>
				Voltar
			</a>
		</div>
	</div>
	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">

			<div class="text-start custom-form">

				<div class="d-flex align-items-center gap-2 mb-2 p-2 bg-light rounded border">
					<i class="bi bi-building-fill text-secondary"></i>
					<div class="text-truncate">
						<small class="text-muted d-block" style="font-size:10px;">ÓRGÃO</small>
						<span class="small fw-bold text-dark text-truncate d-block">
							{{ orgao.nome }}
						</span>
					</div>
				</div>

				<div class="row g-2 mb-2">
					<div class="col-6">
						<div class="p-2 bg-light rounded border d-flex align-items-center gap-2 h-100">
							<i class="bi bi-info-circle-fill text-secondary"></i>
							<div class="text-truncate">
								<small class="text-muted d-block" style="font-size:10px;">TIPO</small>
								<span class="small fw-medium text-dark text-truncate d-block">
									{{ orgao.tipoOrgao.nome|default('Não informado') }}
								</span>
							</div>
						</div>
					</div>

					<div class="col-6">
						<div class="p-2 bg-light rounded border d-flex align-items-center gap-2 h-100">
							<i class="bi bi-telephone-fill text-secondary"></i>
							<div class="text-truncate">
								<small class="text-muted d-block" style="font-size:10px;">TELEFONE</small>
								<span class="small fw-medium text-dark text-truncate d-block">
									{{ orgao.telefone|default('Não informado') }}
								</span>
							</div>
						</div>
					</div>
				</div>

				<div class="d-flex align-items-center gap-2 mb-2 p-2 bg-light rounded border">
					<i class="bi bi-envelope-fill text-secondary"></i>
					<div class="text-truncate">
						<small class="text-muted d-block" style="font-size:10px;">EMAIL</small>
						<span class="small fw-medium text-dark text-truncate d-block">
							{{ orgao.email|default('Não informado') }}
						</span>
					</div>
				</div>

				<div class="d-flex align-items-center gap-2 mb-0 p-2 bg-light rounded border">
					<i class="bi bi-geo-alt-fill text-secondary"></i>
					<div class="text-truncate">
						<small class="text-muted d-block" style="font-size:10px;">LOCALIZAÇÃO</small>
						<span class="small fw-medium text-dark text-truncate d-block">
							{{ [orgao.endereco, orgao.cidade, orgao.estado]|filter(v => v is not empty)|join(', ')|default('Não informado') }}
						</span>
					</div>
				</div>

			</div>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<form class="row g-2 custom-form" method="POST">
				<div class="col-md-4 col-12">
					<input type="text" class="form-control form-control-sm" name="nome" placeholder="Nome*" value="{{orgao.nome}}" required>
				</div>
				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="email" placeholder="Email" value="{{orgao.email}}">
				</div>
				<div class="col-md-5 col-6">
					<input type="text" class="form-control form-control-sm" name="endereco" placeholder="Endereço" value="{{orgao.endereco}}">
				</div>
				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="bairro" placeholder="Bairro" value="{{orgao.bairro}}">
				</div>
				<div class="col-md-2 col-6">
					<select class="form-control form-control-sm" name="estado" id="uf" data-selected="{{orgao.estado}}" required>
						<option disabled selected value="">Escolha o estado*</option>
					</select>
				</div>
				<div class="col-md-2 col-6">
					<select class="form-control form-control-sm" name="cidade" id="municipio" data-selected="{{orgao.cidade}}" required>
						<option disabled selected value="">Selecione o municipio*</option>
					</select>
				</div>
				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="telefone" placeholder="Telefone" value="{{orgao.telefone}}" data-mask="(00) 00000-0000" length="11">
				</div>
				<div class="col-md-4 col-6">
					<div class="input-group">
						<select class="form-control form-control-sm" name="tipo_orgao_id">
							<option value="" {% if orgao.tipo_orgao_id is not defined or orgao.tipo_orgao_id is null %} selected {% endif %}>Tipo não informado</option>

							{% for item in tipos %}
								<option value="{{ item.id }}" {% if orgao.tipo_orgao_id is defined and orgao.tipo_orgao_id == item.id %} selected {% endif %}>
									{{ item.nome }}
								</option>
							{% endfor %}
						</select>
						<a href="/orgaos/tipos" class="btn btn-primary btn-sm confirm" data-message="Deseja inserir um novo tipo?">
							<i class="bi bi-plus-circle"></i>
						</a>
					</div>
				</div>
				<div class="col-md-12 col-12">
					<textarea type="text" class="form-control form-control-sm" name="informacoes" rows="5" placeholder="Informações">{{orgao.informacoes}}</textarea>
				</div>
				<div class="col-md-7">
					<button type="submit" class="btn btn-success btn-sm confirm" data-text="Deseja atualizar esse órgão?" name="btn_salvar">
						<i class="bi bi-floppy-fill"></i>
						Atualizar
					</button>

					<a class="btn btn-danger btn-sm confirm" data-text="Deseja apagar esse órgão?" href="/orgaos/{{orgao.id}}/apagar" name="btn_salvar">
						<i class="bi bi-trash"></i>
						Apagar
					</a>
				</div>
			</form>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<div class="d-flex align-items-center mb-2">
				<h6 class="fw-bold text-muted mb-0 text-uppercase small">Pessoas vinculadas à esse órgão</h6>
			</div>
			<div class="table-responsive mb-0">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col">Nome</th>
							<th scope="col">Vínculo / Profissão</th>
							<th scope="col">Contato</th>
							<th scope="col">Localização</th>
						</tr>
					</thead>
					<tbody>
						{% for pessoa in pessoas %}
							<tr>
								<td>
									<a href="/pessoas/{{ pessoa.id }}">{{ pessoa.nome }}</a>
								</td>

								<td>
									<small class="d-block text-dark">
										<strong>Órgão:</strong>
										{{ pessoa.orgao.nome|default('Não informado') }}</small>
									<small class="d-block text-muted">
										<strong>Profissão:</strong>
										{{ pessoa.profissao.nome|default('Não informada') }}</small>
								</td>

								<td>
									<div class="small">{{ pessoa.email|default('E-mail não informado') }}</div>
									<div class="small text-muted">{{ pessoa.telefone|default('Telefone não informado') }}</div>
								</td>

								<td>
									{{ pessoa.cidade|default('Cidade não informada') }}
									-
									{{ pessoa.estado|default('UF') }}
								</td>


							</tr>
						{% else %}
							<tr>
								<td class="text-muted" colspan="4">Nenhuma pessoa cadastrada</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>


	<script>
		$ (document).ready (function () {
popularEstadosBrasil ('#uf');
popularEstadosBrasil ('#estado');

popularMunicipiosBrasil ('#uf', '#municipio');
});
	</script>
{% endblock %}
