{% extends "layouts/app.twig" %}


{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
		</div>
	</div>


	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<div>
				<h6 class="mb-0 fw-bold mb-1">Gerenciamento de Órgãos e Entidades</h6>
				<small class="text-muted">
					Utilize esta seção para cadastrar, editar, visualizar e remover os órgãos e entidades integrados ao sistema.
				</small>
			</div>
		</div>
	</div>

	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">
			<form class="row g-2 custom-form" method="POST" action="{% if orgao %}/orgaos/{{ tipo.id }}{% else %}/orgaos{% endif %}">
				<div class="col-md-4 col-12">
					<input type="text" class="form-control form-control-sm" name="nome" placeholder="Nome*" required>
				</div>
				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="email" placeholder="Email">
				</div>
				<div class="col-md-5 col-6">
					<input type="text" class="form-control form-control-sm" name="endereco" placeholder="Endereço">
				</div>
				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="bairro" placeholder="Bairro">
				</div>
				<div class="col-md-2 col-6">
					<select class="form-control form-control-sm" name="estado" id="uf" data-selected="{{ estado_gabinete }}" required>
						<option disabled selected value="">Escolha o estado*</option>
					</select>
				</div>
				<div class="col-md-2 col-6">
					<select class="form-control form-control-sm" name="cidade" id="municipio" required>
						<option disabled selected value="">Selecione o municipio*</option>
					</select>
				</div>
				<div class="col-md-2 col-6">
					<input type="text" class="form-control form-control-sm" name="telefone" placeholder="Telefone" data-mask="(00) 00000-0000" length="11">
				</div>
				<div class="col-md-4 col-6">
					<div class="input-group">
						<select class="form-control form-control-sm" name="tipo_orgao_id">
							<option value="" selected>Tipo não informado</option>

							{% for item in tipos %}
								<option value="{{item.id}}">{{item.nome}}</option>
							{% endfor %}

							<option value="+">+ Novo tipo</option>

						</select>
						<a href="/orgaos/tipos" class="btn btn-primary btn-sm confirm" data-text="Deseja inserir um novo tipo?">
							<i class="bi bi-plus-circle"></i>
						</a>
					</div>
				</div>
				<div class="col-md-12 col-12">
					<textarea type="text" class="form-control form-control-sm" name="informacoes" rows="5" placeholder="Informações"></textarea>
				</div>
				<div class="col-md-7">
					<button type="submit" class="btn btn-success btn-sm confirm" data-text="Deseja inserir esse órgão?" name="btn_salvar">
						<i class="bi bi-floppy-fill"></i>
						Salvar
					</button>

				</div>
			</form>
		</div>
	</div>
	<div class="card border-0 shadow-sm">
		<div class="card-body p-3">
			<form class="row g-2 custom-form mb-2" method="GET">
				<div class="col-md-2 col-6">
					<select class="form-control form-control-sm" name="ordenarPor">
						<option value="nome" {% if (parametros.ordenarPor ?? 'nome') == 'nome' %} selected {% endif %}>Ordenar por: Nome</option>
						<option value="created_at" {% if (parametros.ordenarPor ?? 'nome') == 'created_at' %} selected {% endif %}>Ordenar por: Data</option>
						<option value="cidade" {% if (parametros.ordenarPor ?? 'cidade') == 'cidade' %} selected {% endif %}>Ordenar por: Município</option>
					</select>
				</div>

				<div class="col-md-1 col-6">
					<select class="form-control form-control-sm" name="ordem">
						<option value="asc" {% if (parametros.ordem ?? 'asc') == 'asc' %} selected {% endif %}>Crescente</option>
						<option value="desc" {% if (parametros.ordem ?? 'asc') == 'desc' %} selected {% endif %}>Decrescente</option>
					</select>
				</div>

				<div class="col-md-1 col-3">
					<select class="form-control form-control-sm" name="itens">
						<option value="10" {% if (parametros.itens ?? '10') == '10' %} selected {% endif %}>10 itens</option>
						<option value="25" {% if (parametros.itens ?? '25') == '25' %} selected {% endif %}>25 itens</option>
						<option value="50" {% if (parametros.itens ?? '50') == '50' %} selected {% endif %}>50 itens</option>
						<option value="100" {% if (parametros.itens ?? '100') == '100' %} selected {% endif %}>100 itens</option>

					</select>
				</div>

				<div class="col-md-1 col-9">
					<select class="form-control form-control-sm" name="estado" id="estado" data-selected="{{estado_gabinete}}"></select>
				</div>

				<div class="col-md-2 col-12">
					<select class="form-control form-control-sm" name="tipo">
						<option value="" {% if parametros.tipo is not defined or parametros.tipo is null or parametros.tipo === '' %} selected {% endif %}>Mostrar todos os tipos</option>
						<option value="0" {% if parametros.tipo is defined and parametros.tipo === '0' or parametros.tipo === 0 %} selected {% endif %}>Tipo não informado</option>

						{% for item in tipos %}
							<option value="{{ item.id }}" {% if parametros.tipo is defined and parametros.tipo == item.id and parametros.tipo !== '' and parametros.tipo is not null %} selected {% endif %}>
								{{ item.nome }}
							</option>
						{% endfor %}
					</select>
				</div>

				<div class="col-md-3 col-12">
					<input type="text" class="form-control form-control-sm" name="busca" placeholder="Buscar" value="{{parametros.busca}}">
				</div>

				<div class="col-md-1">
					<button type="submit" class="btn btn-success btn-sm">
						<i class="bi bi-search"></i>
					</button>
				</div>
			</form>

			<div class="table-responsive mb-0">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col">Nome</th>
							<th scope="col">Tipo</th>
							<th scope="col">Email | Telefone</th>
							<th scope="col">Localização</th>
						</tr>
					</thead>
					<tbody>
						{% for orgao in orgaos %}
							<tr>
								<td>
									<a href="/orgaos/{{ orgao.id }}">{{ orgao.nome }}</a>
								</td>

								<td>
									{{ orgao.tipoOrgao.nome|default('Não informado') }}
								</td>

								<td>
									{{ orgao.email|default('Não informado') }}
									|
									{{ orgao.email|default('Não informado') }}
								</td>

								<td>
									{{ orgao.endereco|default('Endereço não informado') }}
									-
									{{ orgao.cidade|default('Não informado') }}
									|
									{{ orgao.estado|default('Não informado') }}
								</td>

							</tr>
						{% else %}
							<tr>
								<td class="text-muted" colspan="4">Nenhum órgão cadastrado</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

			{% if total_paginas is defined and total_paginas > 1 %}
				<nav>
					<ul class="pagination mt-2 mb-0 custom-pagination">

						{% set anterior = pagina_atual - 1 %}
						{% set proxima = pagina_atual + 1 %}

						{% if pagina_atual > 1 %}
							{% set query = parametros|merge({'pagina': anterior}) %}
							<li class="page-item">
								<a class="page-link" href="?{{ query|url_encode }}">Anterior</a>
							</li>
						{% endif %}

						{% for pagina in 1..total_paginas %}
							{% set query = parametros|merge({'pagina': pagina}) %}
							<li class="page-item {% if pagina == pagina_atual %}active{% endif %}">
								<a class="page-link" href="?{{ query|url_encode }}">{{ pagina }}</a>
							</li>
						{% endfor %}

						{% if pagina_atual < total_paginas %}
							{% set query = parametros|merge({'pagina': proxima}) %}
							<li class="page-item">
								<a class="page-link" href="?{{ query|url_encode }}">Próxima</a>
							</li>
						{% endif %}
					</ul>
				</nav>

			{% endif %}

		</div>
	</div>
	<script>
		$ (document).ready (function () {
popularEstadosBrasil ('#uf');
popularEstadosBrasil ('#estado');

popularMunicipiosBrasil ('#uf', '#municipio');
});

document.addEventListener ('DOMContentLoaded', function () {
const select = document.querySelector ('select[name="tipo_orgao_id"]');

select.addEventListener ('change', function () {
if (this.value === '+') {
if (confirm ('Deseja inserir um novo tipo?')) {
window.location.href = '/orgaos/tipos';
} else {
this.value = '';
}
}
});
});
	</script>

{% endblock %}
