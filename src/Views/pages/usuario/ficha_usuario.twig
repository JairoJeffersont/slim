{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>
			<a class="btn btn-success btn-sm custom-nav" href="/meu-gabinete" role="button">
				<i class="bi bi-arrow-left"></i>
				Voltar
			</a>
		</div>
	</div>

	<div class="card mb-2 border-0 shadow-sm" style="font-size: 0.9em">
		<div class="card-body p-3">
			<div class="d-flex align-items-center mb-3 pb-3 border-bottom gap-2">
				<h4 class="card-title fw-bold text-dark mb-0">{{ usuario.nome }}</h4>
				{% if usuario.ativo %}
					<span class="badge bg-success-subtle text-success">Ativo</span>
				{% else %}
					<span class="badge bg-danger-subtle text-danger">Desativado</span>
				{% endif %}
			</div>

			<div class="row g-3">
				<div class="col-12 col-md-3">
					<label class="text-muted small d-block">E-mail</label>
					<span class="fw-semibold text-dark">{{ usuario.email|default('') }}</span>
				</div>

				<div class="col-12 col-md-3">
					<label class="text-muted small d-block">Perfil de Acesso</label>
					<span class="fw-semibold text-dark">{{ usuario.tipoUsuario.nome|default('') }}</span>
				</div>
				<div class="col-12 col-md-3">
					<label class="text-muted small d-block">Telefone</label>
					<span class="fw-semibold text-dark">{{ usuario.telefone|default('') }}</span>
				</div>
				<div class="col-12 col-md-3">
					<label class="text-muted small d-block">Aniversário</label>
					<span class="fw-semibold text-dark">{{ usuario.aniversario|date('d/m') }}</span>
				</div>
			</div>
		</div>
	</div>

	<!-- Formulário 1: Tipo de Usuário e Ações Principais -->
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3" style="font-size: 0.9em">

			<h6 class="fw-bold text-muted mb-3">Gerenciamento da conta</h6>
			{% if status == 'success' %}
				<div class="alert alert-success  py-2 px-3	 border-0 small fw-semibold mb-2" data-time="3">
					{{ message }}
				</div>
			{% endif %}
			{% if status == 'info' %}
				<div class="alert alert-info  py-2 px-3	 border-0 small fw-semibold mb-2" data-time="3">
					{{ message }}
				</div>
			{% endif %}

			{% if status == 'server_error' %}
				<div class="alert alert-danger  py-2 px-3 border-0 small fw-semibold mb-2">
					{{ message }}
					<br>
					<small class="opacity-75">ID do Erro:
						{{ error_id }}</small>
				</div>
			{% endif %}
			<div class="d-flex flex-wrap gap-2 align-items-center">

				<form method="POST" action="/usuario/{{ usuario.id }}/tipo" class="d-flex gap-2 align-items-center m-0 custom-form" onsubmit="return confirm('Tem certeza que deseja mudar o nível desse usuário?');">

					<select class="form-select form-select-sm" name="usuario_tipo" style="max-width: 220px;" required>
						{% for tipo in tiposUsuario %}
							<option value="{{ tipo.id }}" {% if usuario.tipo_usuario_id == tipo.id %} selected {% endif %}>
								{{ tipo.nome }}
							</option>
						{% endfor %}
					</select>

					<button type="submit" class="btn btn-primary btn-sm text-nowrap">
						<i class="bi bi-floppy-fill me-1"></i>Atualizar
					</button>
				</form>

				<form method="POST" action="/usuario/{{ usuario.id }}/status" class="m-0 custom-form" onsubmit="return confirm('{% if usuario.ativo %}Tem certeza que deseja desativar esse usuário?{% else %}Tem certeza que deseja ativar esse usuário?{% endif %}');">
					{% if usuario.ativo %}
						<button type="submit" class="btn btn-secondary btn-sm text-nowrap">
							<i class="bi bi-person-x-fill me-1"></i>Desativar
						</button>
					{% else %}
						<button type="submit" class="btn btn-success btn-sm text-nowrap">
							<i class="bi bi-person-check-fill me-1"></i>Ativar
						</button>
					{% endif %}
				</form>

			</div>
		</div>
	</div>


	<div class="card border-0 shadow-sm">
		<div class="card-body p-3">
			<h6 class="fw-bold text-muted mb-3">Últimos Acessos</h6>
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col" class="text-muted fw-semibold">Data/Hora</th>
						</tr>
					</thead>
					<tbody>
						{% for log in usuario.logs %}
							<tr>
								<td class="fw-medium text-dark">{{ log.created_at|date('d/m/Y H:i') }}</td>
							</tr>
						{% else %}
							<tr>
								<td class="fw-medium text-muted">Nenhum acesso registrado</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
