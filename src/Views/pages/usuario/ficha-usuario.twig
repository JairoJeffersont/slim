{% extends "layouts/app.twig" %}

{% block content %}
	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-1">
			<a class="btn btn-primary btn-sm custom-nav" href="/dashboard" role="button">
				<i class="bi bi-house-door-fill"></i>
				Início
			</a>

			<a class="btn btn-success btn-sm custom-nav" href="/gabinete" role="button">
				<i class="bi bi-arrow-left"></i>
				Voltar
			</a>
		</div>
	</div>
	{% if status in ['success', 'info'] %}
		<div class="alert alert-{{ status }} py-2 px-4 border-0 small fw-semibold mb-2" data-time="5">
			{{ message }}
		</div>
	{% endif %}

	{% if status == 'error' %}
		<div class="alert alert-danger py-2 px-4 border-0 small fw-semibold mb-2">
			{{ message }}
			{{ error_id }}
		</div>
	{% endif %}
	<div class="card mb-2 border-0 shadow-sm" style="background: linear-gradient(135deg, #ffffff 10%, #8fc1f2 100%);">
		<div class="card-body p-3">
			<div class="d-flex align-items-center gap-3">
				<div>

					<div class="d-flex align-items-center gap-2 mb-0">
						{% if usuario.tipo_usuario_id == 1 %}
							<span class="badge bg-success-subtle text-black mb-2 fw-light border border-success-subtle rounded-pill x-small">Administrador</span>
						{% endif %}

						{% if usuario.ativo != 1 %}
							<span class="badge bg-danger-subtle text-black mb-2 fw-light border border-danger-subtle rounded-pill x-small">Desativado</span>
						{% endif %}
					</div>

					<h5 class="card-title fw-bold text-dark mb-1">{{ usuario.nome|default('Erro ao buscar') }}</h5>

					<p class="card-text text-muted mb-3 small">
						{{ usuario.email|default('') }}
					</p>

					<p class="card-text text-secondary mb-0 x-small d-flex align-items-center gap-1 opacity-75" style="font-size:0.7em">
						Adicionado em:
						{{ usuario.created_at|date('d/m/Y') }}
					</p>

					{% if usuario.updated_at and usuario.created_at|date('d/m/Y') != usuario.updated_at|date('d/m/Y') %}
						<p class="card-text text-secondary mb-0 x-small d-flex align-items-center gap-1 opacity-75" style="font-size:0.7em">
							Última modificação em:
							{{ usuario.updated_at|date('d/m/Y') }}
						</p>
					{% endif %}
				</div>
			</div>
		</div>
	</div>

	{% if aniversario %}
		<div class="alert alert-info py-2 px-3 border-0 small fw-semibold mb-2">
			<i class="bi bi-cake2 me-2"></i>
			Feliz aniversário
		</div>
	{% endif %}

	<div class="card mb-2 border-0 shadow-sm">
		<div class="card-body p-3">

			<div class="d-flex align-items-center gap-1 mb-3 ">
				<h6 class="fw-bold text-muted mb-0 small">
					Gerenciamento do usuário</h6>
			</div>

			<form class="row g-2 custom-form" id="form_novo" method="POST">

				<div class="col-md-1 col-6">
					<select class="form-select form-select-sm" name="tipo">
						{% for tipo in tipos %}
							<option value="{{ tipo.id }}" {% if tipo.id == usuario.tipo_usuario_id %} selected {% endif %}>{{ tipo.nome }}</option>
						{% endfor %}
					</select>
				</div>

				<div class="col-md-1 col-6">
					<select class="form-select form-select-sm" name="ativo">
						<option value="1" {% if usuario.ativo == 1 %} selected {% endif %}>Ativo</option>
						<option value="0" {% if usuario.ativo == 0 %} selected {% endif %}>Desativado</option>
					</select>
				</div>

				<div class="col-md-2 col-12 d-flex align-items-end">
					<button type="submit" class="btn btn-success btn-sm confirm w-100" data-text="Deseja atualizar seus dados?" name="btn_salvar">
						<i class="bi bi-floppy-fill"></i>
						Salvar
					</button>
				</div>

			</form>
		</div>
	</div>

	<div class="card border-0 shadow-sm">
		<div class="card-body p-3">
			<div class="d-flex align-items-center gap-1 mb-3 ">
				<h6 class="fw-bold text-muted mb-0  small">
					Últimos acessos desse usuário</h6>
			</div>
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0 table-bordered table-striped custom-table">
					<thead>
						<tr>
							<th scope="col" class="text-muted fw-semibold">Data/Hora</th>
						</tr>
					</thead>
					<tbody>
						{% for log in usuario.logs %}
							<tr>
								<td class="fw-medium text-dark">{{ log.created_at|date('d/m/Y H:i') }}</td>
							</tr>
						{% else %}
							<tr>
								<td class="fw-medium text-muted">Nenhum acesso registrado</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>


{% endblock %}
