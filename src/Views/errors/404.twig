{% extends "layouts/app.twig" %}

{% block content %}
	<!-- Container dos Alertas (Posicionados de forma absoluta) -->
	<div class="position-absolute top-0 start-50 translate-middle-x mt-3 w-100 px-3" style="max-width: 500px; z-index: 1050;">
		{% if status in ['success', 'info'] %}
			<div class="alert alert-{{ status }} border-0 shadow-sm py-2 px-3 small d-flex align-items-center rounded-3" data-time="5">
				<i class="bi bi-info-circle-fill me-2"></i>
				<div>{{ message }}</div>
			</div>
		{% endif %}

		{% if status == 'error' %}
			<div class="alert alert-danger border-0 shadow-sm py-2 px-3 small d-flex align-items-center rounded-3">
				<i class="bi bi-x-circle-fill me-2"></i>
				<div>{{ message }}
					<span class="opacity-70 font-monospace" style="font-size: 0.8rem;">({{ error_id }})</span>
				</div>
			</div>
		{% endif %}
	</div>

	<!-- CONTAINER CENTRALIZADO -->
	<div
		class="d-flex align-items-center justify-content-center p-3" style="min-height: 80vh;">

		<!-- CARD MODERNIZADO -->
		<div
			class="card border-0 shadow-sm p-4 p-sm-5 rounded-4 text-center bg-white" style="max-width: 460px; width: 100%;">

			<!-- Ilustração Minimalista -->
			<div class="position-relative d-inline-block mb-4">
				<div class="position-absolute top-50 start-50 translate-middle bg-primary bg-opacity-10 rounded-circle" style="width: 110px; height: 110px; z-index: 0;"></div>
				<i class="bi bi-folder-x text-primary position-relative" style="font-size: 4rem; z-index: 1;"></i>
			</div>

			<!-- Título com Gradiente Moderno -->
			<h1 class="fw-black mb-1" style="font-size: 3rem; letter-spacing: -3px; color: #1e293b; line-height: 1;">
				404
			</h1>

			<h4 class="fw-bold text-dark mb-2" style="font-size: 0.9rem">Página não encontrada</h4>

			<!-- Mensagem Amigável -->
			<p class="text-muted mx-auto mb-4" style="font-size: 0.7rem; line-height: 1.6;">
				O endereço que você tentou acessar não existe, foi removido ou está temporariamente indisponível no sistema do gabinete.
			</p>



		</div>
	</div>

	<!-- Estilos de Transição dos Botões -->
	<style>
		.hover-translate {
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}
		.hover-translate:hover {
			transform: translateY(-1px);
		}
	</style>
{% endblock %}
