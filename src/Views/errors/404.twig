{% extends "layouts/guest.twig" %}

{% block title %}Página Não Encontrada (404)
{% endblock %}

{% block content %}
	<div class="container-fluid min-vh-100 d-flex justify-content-center align-items-center">
		<div class="card border-0 bg-white shadow text-center p-4 p-md-5" style="width: 100%; max-width: 480px; border-radius: 16px;">
			<div
				class="card-body">

				{# Ícone de Lupa/Página do Bootstrap #}
				<div class="mb-4 text-secondary opacity-75">
					<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-file-earmark-break" viewbox="0 0 16 16">
						<path d="M14 4.5V9h-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v7H2V2a2 2 0 0 1 2-2h5.5zM13 12h1v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-3h1v3a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1zM.5 10a.5.5 0 0 1 .5-.5h14a.5.5 0 0 1 0 1H.5a.5.5 0 0 1-.5-.5"/>
					</svg>
				</div>

				{# Número do Erro em Destaque Grande #}
				<h1 class="display-1 fw-bold mb-2 text-primary" style="letter-spacing: -2px; line-height: 1;">404</h1>

				<h4 class="text-dark fw-semibold mb-3">Página não encontrada</h4>

				<p class="text-muted small mb-4">
					O endereço digitado não existe ou a página foi movida para outro local.
					<br>
					Verifique a URL ou retorne ao painel principal.
				</p>

				{# Botão de Ação Principal #}
				<div class="pt-2">
					<a href="/dashboard" class="btn btn-primary rounded-pill px-5 py-2 fw-semibold shadow-sm text-decoration-none">
						Voltar para o Início
					</a>
				</div>

			</div>
		</div>
	</div>
{% endblock %}
