{% extends "layouts/guest.twig" %}

{% block title %}Erro Interno do Servidor (500)
{% endblock %}

{% block content %}
	<div class="container-fluid min-vh-100 d-flex justify-content-center align-items-center">
		<div class="card border-0 bg-white shadow text-center p-4 p-md-5" style="width: 100%; max-width: 480px; border-radius: 16px;">
			<div
				class="card-body">

				{# Ícone de Alerta em Vermelho Suave / Laranja #}
				<div class="mb-4 text-danger opacity-90">
					<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-exclamation-circle-fill" viewbox="0 0 16 16">
						<path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M8 4a.905.905 0 0 0-.9.995l.35 3.507a.552.552 0 0 0 1.1 0l.35-3.507A.905.905 0 0 0 8 4m.002 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/>
					</svg>
				</div>

				{# Número do Erro em Destaque Moderno #}
				<h1 class="display-4 fw-bold mb-2 text-dark" style="letter-spacing: -1px;">Erro 500</h1>

				<h4 class="text-secondary fw-normal mb-3">Algo deu errado no servidor</h4>

				<p class="text-muted small mb-4">
					Ocorreu um erro inesperado ao processar sua solicitação.
					<br>
					Nossa equipe técnica já foi alertada. Por favor, tente novamente em alguns instantes.
				</p>

				{# Bloco do Error ID Sólido (Estilo Painel Cinza) #}
				{% if error_id %}
					<div class="bg-light rounded-3 p-3 mb-4 text-start font-monospace small border d-flex align-items-center justify-content-between">
						<div>
							<span class="text-muted d-block text-uppercase tracking-wider" style="font-size: 0.65rem;">ID do Suporte</span>
							<span class="text-dark fw-bold">{{ error_id }}</span>
						</div>
						<button class="btn btn-sm btn-link text-muted p-0 text-decoration-none hover-primary" onclick="navigator.clipboard.writeText('{{ error_id }}'); alert('ID copiado!');" title="Copiar ID">
							<small>Copiar</small>
						</button>
					</div>
				{% endif %}

				{# Botão de Ação Principal #}
				<div class="pt-2">
					<a href="/dashboard" class="btn btn-primary rounded-pill px-5 py-2 fw-semibold shadow-sm text-decoration-none">
						Voltar para a Página Inicial
					</a>
				</div>

			</div>
		</div>
	</div>

	<style>
		.tracking-wider {
			letter-spacing: 0.05em;
		}
		.hover-primary:hover {
			color: #0d6efd !important;
		}
	</style>
{% endblock %}
