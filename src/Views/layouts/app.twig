<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, user-scalable=no, viewport-fit=cover"/>
		<meta name="description" content="Sistema de Gestão de Gabinete Parlamentar"/>
		<meta name="author" content=""/>
		<title>{{ app_name }}</title>
		<link href="/vendor/bootstrap-5.3.8-dist/css/bootstrap.min.css" rel="stylesheet"/>
		<link href="/css/custom.css" rel="stylesheet"/>
		<link href="/vendor/bootstrap-icons-1.13.1/bootstrap-icons.min.css" rel="stylesheet"/>
		<script src="/vendor/jquery-4.0.0/jquery-4.0.0.min.js"></script>
		<script src="/vendor/jquery-mask/jquery.mask.min.js"></script>
		<script src="/vendor/tinymce-8.5.1/js/tinymce/tinymce.min.js"></script>
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
		<meta name="theme-color" content="#2e13dd" media="(prefers-color-scheme: dark)">

		<meta name="mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
		<meta name="apple-mobile-web-app-title" content="{{ app_name }}"/>
		<link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96"/>
		<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg"/>
		<link rel="shortcut icon" href="/favicon/favicon.ico"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png"/>
		<meta name="apple-mobile-web-app-title" content="Mandato Digital"/>
		<link rel="manifest" href="/favicon/site.webmanifest"/>
		<style>
			body {
				-webkit-tap-highlight-color: transparent;
				-webkit-touch-callout: none;
			}
		</style>
	</head>
	<body>
		<div class="d-flex" id="wrapper">
			{% include 'partials/sidebar.twig' %}
			<div id="page-content-wrapper">
				{% include 'partials/topmenu.twig' %}
				<div class="container-fluid p-2">
					<main>
						{% block content %}{% endblock %}
					</main>
				</div>
			</div>
		</div>
		<script src="/vendor/bootstrap-5.3.8-dist/js/bootstrap.bundle.min.js"></script>
		<script src="/js/scripts.js"></script>
		<script>
    document.addEventListener("DOMContentLoaded", function () {
        // 1. Pega o caminho da URL atual (ex: /pessoas/liderancas)
        const currentPath = window.location.pathname;

        // 2. Procura por todos os links dentro do menu lateral
        const menuLinks = document.querySelectorAll("#sidebarMenu a");

        menuLinks.forEach(link => {
            // Pega o valor do atributo href do link
            const linkPath = link.getAttribute("href");

            // Verifica se a URL atual corresponde ao link
            if (currentPath === linkPath) {
                // Adiciona a classe de ativo no link atual
                link.classList.add("active", "fw-bold", "bg-secondary", "text-white");
                // Remove classes antigas que possam conflitar com o fundo escuro (opcional)
                link.classList.remove("text-secondary");

                // 3. Encontra o menu colapsável pai (o <div class="collapse">)
                const collapseParent = link.closest(".collapse");

                if (collapseParent) {
                    // Adiciona a classe do Bootstrap para deixar o menu aberto
                    collapseParent.classList.add("show");

                    // 4. Encontra o botão que controla esse colapso para mudar a setinha
                    const buttonToggler = document.querySelector(`[data-bs-target="#${collapseParent.id}"]`);
                    if (buttonToggler) {
                        buttonToggler.setAttribute("aria-expanded", "true");
                        buttonToggler.classList.remove("collapsed");
                    }
                }
            }
        });
    });
</script>
	</body>
</html>
