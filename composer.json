{
    "name": "jairo/slim",
    "description": "Sistema de gestão de gabinete parlamentar",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "php",
        "slim-framework",
        "gabinete",
        "gestao-publica",
        "parlamentar",
        "api"
    ],
    "homepage": "https://github.com/jairojeffersont/slim",
    "authors": [
        {
            "name": "Jairo Jefferson Teixeira Dos Santos",
            "email": "jairojeffersont@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/seuusuario/jairojeffersont/slim"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "slim/twig-view": "^3.4",
        "vlucas/phpdotenv": "^5.6",
        "illuminate/database": "^13.9",
        "jairojeffersont/easy-logger": "^1.0",
        "jairojeffersont/easy-file-uploader": "^1.0",
        "phpmailer/phpmailer": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.10",
        "phpstan/phpstan": "^1.12"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs": "phpcs"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
